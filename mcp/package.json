{
  "name": "imaprest-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server wrapper for imaprest \u2014 exposes mail tools to AI agents",
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "node --max-old-space-size=6144 ./node_modules/.bin/tsc --noEmit",
    "lint": "eslint src test",
    "test": "jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
